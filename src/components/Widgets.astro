---
// iOS Widgets showcase section
---

<section class="widgets section-lg">
  <div class="widgets-bg"></div>

  <div class="container">
    <div class="section-header reveal">
      <span class="label label-white">iOS Widgets</span>
      <h2>Your habits, always visible</h2>
      <p>Beautiful widgets that keep your goals front and center on your home screen.</p>
    </div>

    <div class="widgets-showcase">
      <!-- Small Widgets -->
      <div class="widgets-row">
        <div class="widget-card small reveal">
          <div class="widget-content">
            <div class="widget-streak-display">
              <span class="streak-icon">7</span>
              <div class="streak-meta">
                <span class="streak-number">day streak</span>
              </div>
            </div>
            <div class="widget-divider"></div>
            <div class="widget-status done">
              <span class="status-dot"></span>
              Done today
            </div>
            <div class="widget-brand">TinyAct</div>
          </div>
        </div>

        <div class="widget-card small reveal">
          <div class="widget-content centered">
            <div class="progress-ring">
              <svg viewBox="0 0 80 80">
                <circle cx="40" cy="40" r="32" class="progress-bg"></circle>
                <circle cx="40" cy="40" r="32" class="progress-fill"></circle>
              </svg>
              <span class="progress-text">100%</span>
            </div>
            <div class="progress-label">
              <strong>All done!</strong>
              <span>2 of 2 complete</span>
            </div>
            <div class="widget-brand">TinyAct</div>
          </div>
        </div>

        <div class="widget-card small reveal">
          <div class="widget-content">
            <div class="widget-title">Activity</div>
            <div class="activity-stats">
              <div class="stat-row">
                <span class="stat-icon">24</span>
                <span class="stat-label">Check-ins</span>
              </div>
              <div class="stat-row">
                <span class="stat-icon">18</span>
                <span class="stat-label">Reactions</span>
              </div>
            </div>
            <div class="widget-brand">TinyAct</div>
          </div>
        </div>
      </div>
      <div class="widgets-label">Small Widgets</div>

      <!-- Medium Widget -->
      <div class="widgets-row">
        <div class="widget-card medium reveal">
          <div class="widget-content">
            <div class="widget-title">Quick Check-in</div>
            <div class="checkin-list">
              <div class="checkin-item">
                <span class="item-emoji">10</span>
                <span class="item-text">pushups before 9 AM</span>
                <span class="item-streak">7 day streak</span>
                <span class="item-status done">Done</span>
              </div>
              <div class="checkin-item">
                <span class="item-emoji">10</span>
                <span class="item-text">pages before bed</span>
                <span class="item-streak">12 day streak</span>
                <span class="item-status done">Done</span>
              </div>
            </div>
            <div class="widget-brand">TinyAct</div>
          </div>
        </div>
      </div>
      <div class="widgets-label">Medium Widget</div>
    </div>

    <div class="widgets-note reveal">
      <p>Tap any widget to check in instantly. No need to open the app.</p>
    </div>
  </div>
</section>

<style>
  .widgets {
    background: var(--bg-dark-gradient);
    color: var(--white);
    position: relative;
    overflow: hidden;
  }

  .widgets-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 30% 20%, rgba(255, 107, 90, 0.12) 0%, transparent 40%),
      radial-gradient(circle at 70% 80%, rgba(148, 102, 222, 0.12) 0%, transparent 40%);
    pointer-events: none;
  }

  .widgets .section-header {
    text-align: center;
    margin-bottom: var(--space-12);
    position: relative;
    z-index: 1;
  }

  .widgets .section-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-extrabold);
    margin: var(--space-4) 0;
    line-height: var(--leading-tight);
    background: linear-gradient(135deg, var(--coral), var(--coral-light), var(--purple-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .widgets .section-header p {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.75);
    max-width: 500px;
    margin: 0 auto;
  }

  .widgets-showcase {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .widgets-row {
    display: flex;
    justify-content: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .widgets-label {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .widgets-label {
    display: inline-block;
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.7);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    margin: var(--space-3) auto var(--space-8);
  }

  .widget-card {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.92));
    border-radius: var(--radius-2xl);
    padding: var(--space-5);
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.35);
    transition: all var(--transition-slow);
    color: var(--text-primary);
  }

  .widget-card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 45px 120px rgba(0, 0, 0, 0.4);
  }

  .widget-card.small {
    width: 170px;
    height: 170px;
  }

  .widget-card.medium {
    width: 364px;
    height: 170px;
  }

  .widget-content {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .widget-content.centered {
    align-items: center;
    justify-content: center;
  }

  /* Streak Widget */
  .widget-streak-display {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .streak-icon {
    font-size: var(--text-4xl);
    font-weight: var(--font-extrabold);
    color: var(--coral);
  }

  .streak-meta {
    display: flex;
    flex-direction: column;
  }

  .streak-number {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .widget-divider {
    height: 1px;
    background: var(--gray-200);
    margin: var(--space-3) 0;
  }

  .widget-status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-secondary);
  }

  .widget-status.done {
    color: var(--green);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: var(--green);
    border-radius: 50%;
  }

  .widget-brand {
    margin-top: auto;
    text-align: center;
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--coral);
    padding-top: var(--space-2);
  }

  /* Progress Ring Widget */
  .progress-ring {
    position: relative;
    width: 80px;
    height: 80px;
  }

  .progress-ring svg {
    transform: rotate(-90deg);
  }

  .progress-bg {
    fill: none;
    stroke: var(--gray-100);
    stroke-width: 6;
  }

  .progress-fill {
    fill: none;
    stroke: var(--green);
    stroke-width: 6;
    stroke-linecap: round;
    stroke-dasharray: 201;
    stroke-dashoffset: 0;
  }

  .progress-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: var(--text-base);
    font-weight: var(--font-bold);
    color: var(--green);
  }

  .progress-label {
    margin-top: var(--space-2);
    text-align: center;
  }

  .progress-label strong {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
  }

  .progress-label span {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  /* Activity Widget */
  .widget-title {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-muted);
    margin-bottom: var(--space-2);
  }

  .activity-stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .stat-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .stat-icon {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--text-primary);
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  /* Medium Widget - Check-in list */
  .checkin-list {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .checkin-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--gray-100);
  }

  .checkin-item:last-child {
    border-bottom: none;
  }

  .item-emoji {
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--coral);
  }

  .item-text {
    flex: 1;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-primary);
  }

  .item-streak {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .item-status {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
  }

  .item-status.done {
    color: var(--green);
  }

  .widgets-note {
    text-align: center;
    margin-top: var(--space-8);
    position: relative;
    z-index: 1;
  }

  .widgets-note p {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 768px) {
    .widgets-row {
      flex-direction: column;
      align-items: center;
    }

    .widget-card.medium {
      width: 100%;
      max-width: 340px;
    }
  }
</style>
