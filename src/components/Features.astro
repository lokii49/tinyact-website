---
// Features section - Bento grid layout
---

<section class="features section" id="features">
  <div class="container">
    <div class="section-header reveal">
      <span class="label label-coral">Features</span>
      <h2>Everything you need to stay consistent</h2>
      <p>Simple, powerful tools designed around one goal: keeping you accountable.</p>
    </div>

    <div class="bento-grid">
      <!-- Row 1: Two hero cards -->
      <div class="bento-card bento-hero bento-coral reveal">
        <div class="bento-card-inner">
          <div class="feature-icon-lg icon-coral">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3>Partner &amp; Group Accountability</h3>
          <p>Pair with one partner or join a group of up to 8. Enable "All Accountable" mode — one miss resets everyone. Real social cost, real motivation.</p>
          <ul class="feature-pills">
            <li>Partner mode: linked streaks</li>
            <li>Group mode: up to 8 members</li>
            <li>All Members Accountable</li>
          </ul>
        </div>
        <div class="bento-card-glow glow-coral"></div>
      </div>

      <div class="bento-card bento-hero bento-green reveal">
        <div class="bento-card-inner">
          <div class="feature-icon-lg icon-green">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <h3>Photo Proof Check-ins</h3>
          <p>Capture proof with automatic watermarks showing date, time, and streak count. Or go honor-based for privacy. Your choice, your rules.</p>
          <ul class="feature-pills">
            <li>Auto-watermarked photos</li>
            <li>End-to-end encrypted</li>
            <li>Honor-based option</li>
          </ul>
        </div>
        <div class="bento-card-glow glow-green"></div>
      </div>

      <!-- Row 2: Three standard cards -->
      <div class="bento-card bento-std reveal">
        <div class="feature-icon-sm icon-coral">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
          </svg>
        </div>
        <h3>Live Activity Feed</h3>
        <p>Watch your group check in real-time. Their momentum fuels yours.</p>
      </div>

      <div class="bento-card bento-std reveal">
        <div class="feature-icon-sm icon-purple">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"></path>
          </svg>
        </div>
        <h3>Micro-Commitments</h3>
        <p>Tiny specific goals like "10 pushups before 9am". Small wins compound fast.</p>
      </div>

      <div class="bento-card bento-std reveal">
        <div class="feature-icon-sm icon-orange">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <h3>Time-Boxed Goals</h3>
        <p>7, 14, 21, or 30-day sprints. Finite feels achievable. Renew to keep going.</p>
      </div>

      <!-- Row 3: Three standard cards -->
      <div class="bento-card bento-std reveal">
        <div class="feature-icon-sm icon-green">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
        </div>
        <h3>Streak Tracking</h3>
        <p>Build and maintain streaks with a built-in 4-hour grace period. Pause for life.</p>
      </div>

      <div class="bento-card bento-std reveal">
        <div class="feature-icon-sm icon-coral">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
          </svg>
        </div>
        <h3>Smart Nudges</h3>
        <p>Notified when your partner checks in. Reminders calibrated to your schedule.</p>
      </div>

      <div class="bento-card bento-std reveal">
        <div class="feature-icon-sm icon-purple">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
        </div>
        <h3>Reactions</h3>
        <p>Quick emoji reactions to celebrate completions — no awkward comments needed.</p>
      </div>

      <!-- Row 4: Three standard cards -->
      <div class="bento-card bento-std reveal">
        <div class="feature-icon-sm icon-orange">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
          </svg>
        </div>
        <h3>18 Awards</h3>
        <p>Unlock achievements across 5 categories: Streaks, Comebacks, Consistency, Social, Proof.</p>
      </div>

      <div class="bento-card bento-std reveal">
        <div class="feature-icon-sm icon-coral">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path>
            <line x1="4" y1="22" x2="4" y2="15"></line>
          </svg>
        </div>
        <h3>Comeback Tracking</h3>
        <p>Missed days? Track your comebacks and rise stronger after breaks.</p>
      </div>

      <div class="bento-card bento-std reveal">
        <div class="feature-icon-sm icon-green">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="8" y1="21" x2="16" y2="21"></line>
            <line x1="12" y1="17" x2="12" y2="21"></line>
          </svg>
        </div>
        <h3>iOS Widgets</h3>
        <p>Track progress from your home screen. Small, medium, and large widget sizes.</p>
      </div>

      <!-- Row 5: Full-width XP card -->
      <div class="bento-card bento-wide bento-xp reveal">
        <div class="bento-card-inner bento-wide-inner">
          <div class="feature-icon-lg icon-purple">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"></path>
              <line x1="16" y1="8" x2="2" y2="22"></line>
              <line x1="17.5" y1="15" x2="9" y2="15"></line>
            </svg>
          </div>
          <div class="bento-wide-text">
            <h3>XP &amp; Levels</h3>
            <p>Earn experience points for every check-in, reaction, and achievement. Watch your level climb as your habits solidify — a visible reminder of how far you've come.</p>
          </div>
          <div class="xp-display" aria-hidden="true">
            <div class="xp-bar-wrap">
              <div class="xp-label">Level 7</div>
              <div class="xp-bar"><div class="xp-fill"></div></div>
              <div class="xp-next">2,840 / 3,500 XP</div>
            </div>
          </div>
        </div>
        <div class="bento-card-glow glow-purple"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--bg-secondary);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-extrabold);
    margin: var(--space-4) 0;
    line-height: var(--leading-tight);
    color: var(--text-primary);
  }

  .section-header p {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  /* Bento Grid */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-5);
  }

  /* Card base */
  .bento-card {
    background: var(--white);
    border-radius: var(--radius-2xl);
    padding: var(--space-7);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06), 0 1px 2px rgba(0, 0, 0, 0.04);
    transition: transform var(--transition-slow), box-shadow var(--transition-slow);
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.04);
  }

  .bento-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.1), 0 4px 12px rgba(0, 0, 0, 0.06);
  }

  /* Hero cards (span 3 each) */
  .bento-hero {
    grid-column: span 3;
    padding: var(--space-8);
  }

  /* Standard cards (span 2 each) */
  .bento-std {
    grid-column: span 2;
  }

  /* Wide / full-width card */
  .bento-wide {
    grid-column: span 6;
    padding: var(--space-8);
  }

  /* Color accent glows */
  .bento-card-glow {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    bottom: -120px;
    right: -80px;
    pointer-events: none;
    filter: blur(60px);
    opacity: 0.18;
    transition: opacity var(--transition-slow);
  }

  .bento-card:hover .bento-card-glow {
    opacity: 0.28;
  }

  .glow-coral { background: var(--coral); }
  .glow-green { background: var(--green); }
  .glow-purple { background: var(--purple); }

  /* Color accents on cards */
  .bento-coral { border-top: 3px solid var(--coral); }
  .bento-green { border-top: 3px solid var(--green); }
  .bento-xp    { border-top: 3px solid var(--purple); }

  /* Card inner layout */
  .bento-card-inner {
    position: relative;
    z-index: 1;
  }

  /* Icon sizes */
  .feature-icon-lg {
    width: 60px;
    height: 60px;
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-5);
    flex-shrink: 0;
  }

  .feature-icon-sm {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-4);
    flex-shrink: 0;
  }

  /* Icon color variants */
  .icon-coral {
    background: linear-gradient(135deg, rgba(255, 107, 90, 0.14), rgba(255, 107, 90, 0.06));
    color: var(--coral);
  }

  .icon-green {
    background: linear-gradient(135deg, rgba(87, 199, 96, 0.14), rgba(87, 199, 96, 0.06));
    color: var(--green-dark);
  }

  .icon-purple {
    background: linear-gradient(135deg, rgba(148, 102, 222, 0.14), rgba(148, 102, 222, 0.06));
    color: var(--purple);
  }

  .icon-orange {
    background: linear-gradient(135deg, rgba(255, 115, 46, 0.14), rgba(255, 115, 46, 0.06));
    color: var(--orange);
  }

  /* Card typography */
  .bento-card h3 {
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
    line-height: var(--leading-snug);
  }

  .bento-hero h3 {
    font-size: var(--text-xl);
  }

  .bento-card p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .bento-hero p {
    font-size: var(--text-base);
    margin-bottom: var(--space-5);
  }

  /* Feature pills */
  .feature-pills {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .feature-pills li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: var(--font-medium);
  }

  .feature-pills li::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--coral);
  }

  .bento-green .feature-pills li::before {
    background: var(--green);
  }

  /* Wide card inner */
  .bento-wide-inner {
    display: flex;
    align-items: center;
    gap: var(--space-10);
  }

  .bento-wide-text {
    flex: 1;
  }

  .bento-wide-text h3 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-3);
  }

  .bento-wide-text p {
    font-size: var(--text-base);
    max-width: 480px;
    margin-bottom: 0;
  }

  /* XP bar display */
  .xp-display {
    flex-shrink: 0;
    width: 220px;
  }

  .xp-bar-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .xp-label {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--purple);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .xp-bar {
    height: 10px;
    background: rgba(148, 102, 222, 0.12);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .xp-fill {
    height: 100%;
    width: 81%;
    background: linear-gradient(90deg, var(--purple), var(--purple-light));
    border-radius: var(--radius-full);
    animation: xp-grow 1.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    transform-origin: left;
  }

  @keyframes xp-grow {
    from { width: 0%; }
    to { width: 81%; }
  }

  .xp-next {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-weight: var(--font-medium);
  }

  /* Responsive */
  @media (max-width: 1200px) {
    .bento-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .bento-hero {
      grid-column: span 2;
    }

    .bento-std {
      grid-column: span 2;
    }

    .bento-wide {
      grid-column: span 4;
    }
  }

  @media (max-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .bento-hero {
      grid-column: span 2;
    }

    .bento-std {
      grid-column: span 1;
    }

    .bento-wide {
      grid-column: span 2;
    }

    .bento-wide-inner {
      flex-direction: column;
      gap: var(--space-6);
    }

    .xp-display {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .bento-std {
      grid-column: span 2;
    }
  }
</style>
