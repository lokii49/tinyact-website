---
// Hero section - the first impression that drives conversion
---

<section class="hero" id="main-content">
  <div class="hero-bg">
    <div class="hero-gradient"></div>
    <div class="hero-orb orb-1"></div>
    <div class="hero-orb orb-2"></div>
    <div class="hero-orb orb-3"></div>
  </div>

  <div class="container hero-container">
    <div class="hero-content">
      <span class="label label-coral">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83z"/>
        </svg>
        Available on iOS & Android
      </span>

      <h1>
        The habit app where <span class="text-gradient">quitting doesn't just affect only you</span>
      </h1>

      <p class="hero-subtitle">
        Pair with an accountability partner or join a group. If one person breaks the streak, everyone feels it. Real social cost creates real motivation.
      </p>

      <div class="hero-cta">
        <a href="https://apps.apple.com/app/tinyact" class="store-badge" target="_blank" rel="noopener">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <div class="store-badge-text">
            <span class="store-badge-sub">Download on the</span>
            <span class="store-badge-name">App Store</span>
          </div>
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.lokesh.Tinyact" class="store-badge" target="_blank" rel="noopener">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3,20.5V3.5C3,2.91 3.34,2.36 3.84,2.07L13.69,12L3.84,21.93C3.34,21.64 3,21.09 3,20.5M16.81,15.12L13.7,12L16.81,8.88L20.61,11.07C21.67,11.67 21.67,12.33 20.61,12.93L16.81,15.12M5.57,23.09L14.18,14.5L16.81,15.12L7.68,21.5C6.77,22.03 5.89,22.21 5.57,23.09M5.57,0.91C5.89,1.79 6.77,1.97 7.68,2.5L16.81,8.88L14.18,9.5L5.57,0.91Z"/>
          </svg>
          <div class="store-badge-text">
            <span class="store-badge-sub">Get it on</span>
            <span class="store-badge-name">Google Play</span>
          </div>
        </a>
        <a href="#how-it-works" class="btn btn-outline">See How It Works</a>
      </div>

      <p class="hero-note">Free forever. No credit card required.</p>

      <div class="hero-trust">
        <div class="trust-stars" aria-label="4.8 out of 5 stars">★★★★★</div>
        <span class="trust-rating">4.8</span>
        <span class="trust-sep">·</span>
        <span class="trust-text">Free on iOS &amp; Android</span>
      </div>
    </div>

    <div class="hero-visual">
      <div class="phone-showcase">
        <!-- Main phone -->
        <div class="phone phone-main">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <img src="/screenshots/screen-my-goals.png" alt="TinyAct My Goals screen showing active streaks and commitments" loading="eager">
          </div>
        </div>

        <!-- Secondary phone (offset behind) -->
        <div class="phone phone-secondary">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <img src="/screenshots/feedview.jpeg" alt="TinyAct Live Activity Feed showing real-time check-ins" loading="eager">
          </div>
        </div>
      </div>

      <!-- Floating badge — streak -->
      <div class="floating-badge">
        <div class="badge-pulse"></div>
        <div class="badge-icon">🔥</div>
        <div class="badge-text">
          <strong>12 day streak</strong>
          <span>Partner completed today</span>
        </div>
      </div>

      <!-- Floating badge — notification -->
      <div class="floating-badge floating-badge-notify">
        <div class="badge-notify-dot"></div>
        <div class="badge-icon">✅</div>
        <div class="badge-text">
          <strong>Alex checked in</strong>
          <span>2 min ago · Day 12</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 8rem 0 4rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 10% 20%, rgba(255, 107, 90, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse 60% 50% at 90% 80%, rgba(148, 102, 222, 0.06) 0%, transparent 50%),
      linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
  }

  .orb-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 107, 90, 0.12) 0%, transparent 70%);
    filter: blur(60px);
    top: -180px;
    left: -140px;
    animation: orb-drift-1 14s ease-in-out infinite;
  }

  .orb-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(148, 102, 222, 0.1) 0%, transparent 70%);
    filter: blur(50px);
    bottom: -80px;
    right: 25%;
    animation: orb-drift-2 18s ease-in-out infinite;
  }

  .orb-3 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(87, 199, 96, 0.09) 0%, transparent 70%);
    filter: blur(40px);
    top: 35%;
    right: -60px;
    animation: orb-drift-3 16s ease-in-out infinite;
  }

  @keyframes orb-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, -30px) scale(1.05); }
    66% { transform: translate(-20px, 25px) scale(0.95); }
  }

  @keyframes orb-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    40% { transform: translate(-35px, -20px) scale(1.08); }
    70% { transform: translate(25px, 15px) scale(0.96); }
  }

  @keyframes orb-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(20px, -40px) scale(1.1); }
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-content {
    max-width: 560px;
    position: relative;
    z-index: 5;
  }

  .hero h1 {
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 1.5rem 0;
    color: var(--text-primary);
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--coral) 0%, var(--orange) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .hero-note {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  /* Phone showcase */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 620px;
    z-index: 1;
  }

  .phone-showcase {
    position: relative;
    width: 420px;
    height: 600px;
  }

  .phone {
    position: absolute;
    width: 240px;
    background: linear-gradient(145deg, #2a2a2a 0%, #1a1a1a 100%);
    border-radius: 36px;
    padding: 6px;
    box-shadow:
      0 25px 60px -12px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .phone-notch {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 22px;
    background: #000;
    border-radius: 11px;
    z-index: 10;
  }

  .phone-main {
    z-index: 3;
    left: 20px;
    top: 20px;
    transform: rotate(-6deg);
  }

  .phone-secondary {
    z-index: 2;
    right: 20px;
    top: 60px;
    transform: rotate(8deg);
  }

  .phone-screen {
    background: #000;
    border-radius: 30px;
    overflow: hidden;
  }

  .phone-screen img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Floating badge */
  .floating-badge {
    position: absolute;
    bottom: 40px;
    left: 10px;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--white);
    padding: 0.75rem 1rem;
    border-radius: 1rem;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    z-index: 10;
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .badge-pulse {
    position: absolute;
    inset: -4px;
    background: var(--coral);
    border-radius: 1.25rem;
    opacity: 0;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0; transform: scale(1); }
    50% { opacity: 0.15; transform: scale(1.05); }
  }

  .badge-icon {
    font-size: 1.5rem;
    position: relative;
  }

  .badge-text {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .badge-text strong {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .badge-text span {
    font-size: 0.75rem;
    color: var(--green);
  }

  /* Second floating badge (notification) */
  .floating-badge-notify {
    position: absolute;
    top: 30px;
    right: 0px;
    animation: float-notify 4s ease-in-out infinite;
    animation-delay: 1.5s;
    z-index: 10;
  }

  .badge-notify-dot {
    position: absolute;
    top: -3px;
    right: -3px;
    width: 10px;
    height: 10px;
    background: var(--green);
    border-radius: 50%;
    border: 2px solid var(--white);
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes float-notify {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Trust bar */
  .hero-trust {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .trust-stars {
    color: var(--yellow);
    font-size: var(--text-sm);
    letter-spacing: 1px;
  }

  .trust-rating {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--text-primary);
  }

  .trust-sep {
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .trust-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  /* Label */
  .label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .label-coral {
    background: rgba(255, 107, 90, 0.1);
    color: var(--coral);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero {
      padding: 7rem 0 3rem;
      min-height: auto;
    }

    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero-content {
      max-width: 100%;
      order: 1;
    }

    .hero-visual {
      order: 2;
      min-height: 480px;
    }

    .hero-cta {
      justify-content: center;
    }

    .phone-showcase {
      width: 340px;
      height: 480px;
    }

    .phone {
      width: 200px;
    }

    .phone-main {
      left: 30px;
      top: 10px;
      transform: rotate(-4deg);
    }

    .phone-secondary {
      right: 30px;
      top: 40px;
      transform: rotate(6deg);
    }

    .floating-badge {
      left: 50%;
      transform: translateX(-50%);
      bottom: 20px;
    }

    .floating-badge-notify {
      top: 10px;
      right: 10px;
    }

    .hero-trust {
      justify-content: center;
    }

    @keyframes float {
      0%, 100% { transform: translateX(-50%) translateY(0); }
      50% { transform: translateX(-50%) translateY(-6px); }
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 6rem 0 2rem;
    }

    .hero h1 {
      font-size: 1.875rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .hero-cta {
      flex-direction: column;
      align-items: center;
    }

    .hero-cta .btn {
      width: 100%;
      max-width: 280px;
    }

    .phone-showcase {
      width: 280px;
      height: 420px;
    }

    .phone {
      width: 180px;
    }

    .phone-main {
      left: 50%;
      transform: translateX(-50%) rotate(0deg);
    }

    .phone-secondary {
      display: none;
    }

    .floating-badge {
      display: none;
    }

    .floating-badge-notify {
      display: none;
    }

    .hero-trust {
      justify-content: center;
    }
  }
</style>
