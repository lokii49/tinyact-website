---
// Accountability section - The core differentiator: Partner & Group modes
---

<section class="accountability section-lg" id="accountability">
  <div class="accountability-bg"></div>

  <div class="container">
    <div class="section-header reveal">
      <span class="label label-white">What Makes TinyAct Different</span>
      <h2>Two powerful ways to stay accountable</h2>
      <p>Choose partner mode for one-on-one commitment, or group mode for team-based accountability. Both create real social cost when you skip.</p>
    </div>

    <div class="accountability-modes">
      <!-- Partner Mode -->
      <div class="mode-card reveal">
        <div class="mode-badge partner">
          <span class="mode-emoji">2</span>
          <span class="mode-label">Partner Mode</span>
        </div>

        <h3>Linked Streaks</h3>
        <p class="mode-desc">Pair with one accountability partner. Your streaks are connected - if one breaks, both restart at zero.</p>

        <div class="mode-visual">
          <div class="partner-visual">
            <div class="partner-user">
              <div class="avatar" style="background: linear-gradient(135deg, #FF6B5A, #FF8F7A);">Y</div>
              <div class="user-info">
                <span class="name">You</span>
                <span class="status done">Done today</span>
              </div>
            </div>
            <div class="connection">
              <div class="connection-line"></div>
              <div class="connection-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF6B5A" stroke-width="2">
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                </svg>
              </div>
              <div class="connection-line"></div>
            </div>
            <div class="partner-user">
              <div class="avatar" style="background: linear-gradient(135deg, #9466DE, #A880E8);">S</div>
              <div class="user-info">
                <span class="name">Sarah</span>
                <span class="status done">Done today</span>
              </div>
            </div>
          </div>
          <div class="streak-display partner-streak">
            <span class="streak-fire">21</span>
            <span class="streak-text">day streak together</span>
          </div>
        </div>

        <ul class="mode-features">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
            If one person misses, both streaks reset
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
            Real-time notifications when partner checks in
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
            Share reactions to celebrate each other
          </li>
        </ul>
      </div>

      <!-- Group Mode -->
      <div class="mode-card reveal">
        <div class="mode-badge group">
          <span class="mode-emoji">8</span>
          <span class="mode-label">Group Mode</span>
        </div>

        <h3>All-Members Accountability</h3>
        <p class="mode-desc">Join a group of up to 8 members. Enable "All Accountable" mode - one person misses, everyone's streak resets.</p>

        <div class="mode-visual">
          <div class="group-visual">
            <div class="group-avatars">
              <div class="avatar" style="background: linear-gradient(135deg, #FF6B5A, #FF8F7A);">Y</div>
              <div class="avatar" style="background: linear-gradient(135deg, #57C760, #7BD982);">M</div>
              <div class="avatar" style="background: linear-gradient(135deg, #9466DE, #A880E8);">J</div>
              <div class="avatar" style="background: linear-gradient(135deg, #3B82F6, #60A5FA);">K</div>
              <div class="avatar more">+2</div>
            </div>
            <div class="group-name">Morning Workout Crew</div>
            <div class="group-status">
              <span class="status-indicator"></span>
              <span>4 of 6 checked in today</span>
            </div>
          </div>
          <div class="streak-display group-streak">
            <span class="streak-fire">14</span>
            <span class="streak-text">day group streak</span>
          </div>
        </div>

        <ul class="mode-features">
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
            Teams of 3-8 people for maximum accountability
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
            Optional: All Members Accountable mode
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
            Live activity feed within the group
          </li>
        </ul>
      </div>
    </div>

    <!-- Social Psychology callout -->
    <div class="psychology-callout reveal">
      <div class="callout-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
        </svg>
      </div>
      <div class="callout-content">
        <h4>Built on behavioral science</h4>
        <p>Research shows we're 65% more likely to achieve goals when we commit to another person, and 95% more likely when we have regular accountability meetings. TinyAct automates this with daily check-ins and real consequences for missing.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .accountability {
    background: var(--bg-dark-gradient);
    color: var(--white);
    position: relative;
    overflow: hidden;
  }

  .accountability-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 20% 30%, rgba(148, 102, 222, 0.2) 0%, transparent 50%),
      radial-gradient(ellipse 50% 40% at 80% 70%, rgba(255, 107, 90, 0.2) 0%, transparent 50%);
    pointer-events: none;
  }

  .accountability .section-header {
    text-align: center;
    margin-bottom: var(--space-16);
    position: relative;
    z-index: 1;
  }

  .accountability .section-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-extrabold);
    margin: var(--space-4) 0;
    line-height: var(--leading-tight);
    color: var(--white);
  }

  .accountability .section-header p {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.75);
    max-width: 650px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .accountability-modes {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
    position: relative;
    z-index: 1;
    margin-bottom: var(--space-16);
  }

  .mode-card {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.92));
    border-radius: var(--radius-3xl);
    padding: var(--space-10);
    color: var(--text-primary);
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.3);
    transition: all var(--transition-slow);
  }

  .mode-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 50px 120px rgba(0, 0, 0, 0.35);
  }

  .mode-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-4);
  }

  .mode-badge.partner {
    background: linear-gradient(135deg, rgba(255, 107, 90, 0.15), rgba(255, 107, 90, 0.05));
    color: var(--coral);
  }

  .mode-badge.group {
    background: linear-gradient(135deg, rgba(148, 102, 222, 0.15), rgba(148, 102, 222, 0.05));
    color: var(--purple);
  }

  .mode-emoji {
    font-size: var(--text-lg);
    font-weight: var(--font-extrabold);
  }

  .mode-card h3 {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-3);
    color: var(--text-primary);
  }

  .mode-desc {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }

  .mode-visual {
    background: var(--gray-50);
    border-radius: var(--radius-2xl);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
  }

  /* Partner Visual */
  .partner-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .partner-user {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    font-weight: var(--font-bold);
    font-size: var(--text-lg);
  }

  .user-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .user-info .name {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
  }

  .user-info .status {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .user-info .status.done {
    color: var(--green);
    font-weight: var(--font-medium);
  }

  .connection {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .connection-line {
    width: 30px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--coral), transparent);
  }

  .connection-icon {
    background: rgba(255, 107, 90, 0.1);
    border-radius: 50%;
    padding: var(--space-2);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Group Visual */
  .group-visual {
    text-align: center;
  }

  .group-avatars {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-3);
  }

  .group-avatars .avatar {
    width: 44px;
    height: 44px;
    font-size: var(--text-sm);
    margin-left: -8px;
    border: 3px solid var(--white);
  }

  .group-avatars .avatar:first-child {
    margin-left: 0;
  }

  .group-avatars .avatar.more {
    background: var(--gray-200);
    color: var(--text-secondary);
    font-size: var(--text-xs);
  }

  .group-name {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .group-status {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .status-indicator {
    width: 8px;
    height: 8px;
    background: var(--yellow);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* Streak Display */
  .streak-display {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-4);
    background: linear-gradient(135deg, rgba(255, 107, 90, 0.1), rgba(255, 107, 90, 0.05));
    border-radius: var(--radius-xl);
    margin-top: var(--space-4);
  }

  .streak-fire {
    font-size: var(--text-3xl);
    font-weight: var(--font-extrabold);
    color: var(--coral);
  }

  .streak-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  /* Mode Features */
  .mode-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .mode-features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
  }

  .mode-features li svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Psychology Callout */
  .psychology-callout {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    position: relative;
    z-index: 1;
  }

  .callout-icon {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, var(--coral), var(--coral-light));
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--white);
  }

  .callout-content h4 {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--white);
    margin-bottom: var(--space-2);
  }

  .callout-content p {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.75);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 1024px) {
    .accountability-modes {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .mode-card {
      padding: var(--space-6);
    }

    .partner-visual {
      flex-direction: column;
    }

    .connection {
      transform: rotate(90deg);
    }

    .psychology-callout {
      flex-direction: column;
      text-align: center;
    }

    .callout-icon {
      margin: 0 auto;
    }
  }
</style>
