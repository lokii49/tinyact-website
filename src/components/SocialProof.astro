---
// Social Proof section - Testimonials and example outcomes
---

<section class="social-proof section">
  <div class="container">
    <div class="section-header reveal">
      <span class="label label-coral">Real Results</span>
      <h2>What accountability looks like in practice</h2>
      <p>The science and features behind building lasting habits.</p>
    </div>

    <div class="stats-banner reveal">
      <div class="stat-item">
        <span class="stat-number">65%</span>
        <span class="stat-desc">more likely to complete goals with a partner</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">21</span>
        <span class="stat-desc">days to form a lasting habit</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">4h</span>
        <span class="stat-desc">grace period so life doesn't ruin your streak</span>
      </div>
    </div>
  </div>
</section>

<style>
  .social-proof {
    background: var(--bg-primary);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-extrabold);
    margin: var(--space-4) 0;
    line-height: var(--leading-tight);
    color: var(--text-primary);
  }

  .section-header p {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  /* Stats Banner */
  .stats-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-12);
    background: linear-gradient(135deg, var(--gray-900), var(--gray-800));
    border-radius: var(--radius-3xl);
    padding: var(--space-10) var(--space-12);
    color: var(--white);
  }

  .stat-item {
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: var(--text-5xl);
    font-weight: var(--font-extrabold);
    background: linear-gradient(135deg, var(--coral), var(--coral-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .stat-desc {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
    max-width: 180px;
    display: block;
    line-height: var(--leading-snug);
  }

  .stat-divider {
    width: 1px;
    height: 60px;
    background: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 1024px) {
    .stats-banner {
      flex-direction: column;
      gap: var(--space-6);
      padding: var(--space-8);
    }

    .stat-divider {
      width: 60px;
      height: 1px;
    }

    .stat-desc {
      max-width: 100%;
    }
  }
</style>
