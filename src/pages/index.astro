---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Accountability from '../components/Accountability.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Features from '../components/Features.astro';
import Widgets from '../components/Widgets.astro';
import SocialProof from '../components/SocialProof.astro';
import Privacy from '../components/Privacy.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="TinyAct - Build Habits With Real Accountability"
  description="The habit app where quitting doesn't just affect you. Partner and group accountability that creates real social cost and motivation. Download free for iOS."
>
  <Header />
  <main>
    <Hero />
    <Problem />
    <Accountability />
    <HowItWorks />
    <Features />
    <Widgets />
    <SocialProof />
    <Privacy />
    <FinalCTA />
  </main>
  <Footer />
</Layout>
