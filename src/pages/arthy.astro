---
// tinyact.app/arthy — a love letter
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>To Arthy, my love ❤️</title>
  <meta name="description" content="A love letter.">
  <meta name="robots" content="noindex, nofollow">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Crimson+Pro:ital,wght@0,300;0,400;1,300;1,400&family=Courier+Prime:ital,wght@0,400;1,400&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --ink: #1c1410;
      --ink-soft: #3d2f27;
      --ink-muted: #7a6558;
      --cream: #faf5ec;
      --cream-dark: #f0e8d8;
      --red: #c0392b;
      --red-soft: #e05a4a;
      --gold: #a07840;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background-color: var(--cream);
      color: var(--ink);
      font-family: 'Crimson Pro', Georgia, serif;
      font-size: 20px;
      line-height: 1.75;
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
    }

    /* Grain overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 1000;
      opacity: 0.35;
    }

    /* Envelope wax-seal top border */
    .top-seal {
      width: 100%;
      height: 6px;
      background: linear-gradient(90deg, var(--red) 0%, #e8593a 40%, var(--red) 70%, #9b2c1e 100%);
    }

    .page {
      max-width: 680px;
      margin: 0 auto;
      padding: 72px 32px 120px;
    }

    /* --- Header --- */
    .letter-header {
      text-align: center;
      margin-bottom: 56px;
      opacity: 0;
      animation: fadeUp 1.2s ease forwards;
      animation-delay: 0.2s;
    }

    .letter-header h1 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      font-size: clamp(2.4rem, 6vw, 3.6rem);
      line-height: 1.15;
      letter-spacing: -0.01em;
      color: var(--ink);
    }

    .letter-header h1 .heart {
      color: var(--red);
      display: inline-block;
      animation: heartbeat 2.4s ease-in-out infinite;
    }

    .letter-header .subtitle {
      font-family: 'Crimson Pro', serif;
      font-style: italic;
      font-weight: 300;
      font-size: 1.05rem;
      color: var(--ink-muted);
      margin-top: 10px;
      letter-spacing: 0.04em;
    }

    .divider {
      width: 48px;
      height: 1px;
      background: var(--gold);
      margin: 20px auto;
      opacity: 0.6;
    }

    /* --- Body text --- */
    .letter-body {
      opacity: 0;
      animation: fadeUp 1.2s ease forwards;
      animation-delay: 0.5s;
    }

    .letter-body p {
      font-size: 1.15rem;
      line-height: 1.85;
      color: var(--ink-soft);
      margin-bottom: 1.2em;
    }

    /* Blockquote */
    .letter-body blockquote {
      border-left: 3px solid var(--red-soft);
      padding-left: 20px;
      margin: 28px 0;
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.35rem;
      font-weight: 400;
      color: var(--ink);
      line-height: 1.5;
    }

    /* Monospace box */
    .letter-body .mono-box {
      background: var(--cream-dark);
      border: 1px solid #d8c8b4;
      border-radius: 4px;
      padding: 18px 22px;
      margin: 28px 0;
      font-family: 'Courier Prime', 'Courier New', monospace;
      font-size: 0.92rem;
      line-height: 1.7;
      color: var(--ink);
    }

    /* --- Photo --- */
    .photo-section {
      margin: 48px -32px;
      opacity: 0;
      animation: fadeUp 1.4s ease forwards;
      animation-delay: 0.8s;
      position: relative;
    }

    .photo-section img {
      width: 100%;
      height: auto;
      display: block;
    }

    .photo-caption {
      text-align: center;
      font-family: 'Crimson Pro', serif;
      font-style: italic;
      font-size: 0.82rem;
      color: var(--ink-muted);
      margin-top: 12px;
      letter-spacing: 0.03em;
    }

    /* --- Day counter --- */
    .day-counter {
      text-align: left;
      margin: 48px 0 32px;
      opacity: 0;
      animation: fadeUp 1.2s ease forwards;
      animation-delay: 1.0s;
    }

    .day-counter .count {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      font-size: clamp(2.8rem, 7vw, 4.2rem);
      color: var(--ink);
      line-height: 1;
      letter-spacing: -0.02em;
    }

    .day-counter .count-icons {
      font-size: 1.6rem;
      vertical-align: middle;
      margin-left: 6px;
    }

    .day-counter .count-label {
      font-family: 'Crimson Pro', serif;
      font-style: italic;
      font-size: 0.85rem;
      color: var(--ink-muted);
      letter-spacing: 0.06em;
      margin-top: 4px;
    }

    /* --- Letter continuation --- */
    .letter-continuation {
      opacity: 0;
      animation: fadeUp 1.2s ease forwards;
      animation-delay: 1.2s;
    }

    .letter-continuation p {
      font-size: 1.15rem;
      line-height: 1.9;
      color: var(--ink-soft);
      margin-bottom: 1.4em;
    }

    .letter-continuation .tinyact-line {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.22rem;
      color: var(--ink);
      border-left: none;
      padding: 0;
      margin-bottom: 1.8em;
    }

    .letter-continuation .tinyact-line .brand {
      font-style: normal;
      font-weight: 600;
    }

    /* --- Signature --- */
    .signature {
      margin-top: 40px;
      opacity: 0;
      animation: fadeUp 1.2s ease forwards;
      animation-delay: 1.5s;
    }

    .signature .closing {
      font-family: 'Crimson Pro', serif;
      font-size: 1.05rem;
      color: var(--ink-muted);
      margin-bottom: 2px;
    }

    .signature .from {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      font-size: 1.4rem;
      color: var(--ink);
    }

    .signature .timestamp {
      font-family: 'Courier Prime', monospace;
      font-size: 0.78rem;
      color: var(--ink-muted);
      margin-top: 32px;
      text-align: right;
      letter-spacing: 0.04em;
    }

    /* --- Footer decoration --- */
    .bottom-seal {
      width: 100%;
      height: 4px;
      background: linear-gradient(90deg, transparent 0%, var(--red) 30%, #e8593a 50%, var(--red) 70%, transparent 100%);
      opacity: 0.5;
      margin-top: 80px;
    }

    /* Floating hearts */
    .hearts-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 500;
      overflow: hidden;
    }

    .floating-heart {
      position: absolute;
      bottom: -20px;
      font-size: 14px;
      opacity: 0;
      animation: floatHeart linear infinite;
      color: var(--red);
    }

    /* --- Animations --- */
    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(22px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes heartbeat {
      0%, 100% { transform: scale(1); }
      14% { transform: scale(1.25); }
      28% { transform: scale(1); }
      42% { transform: scale(1.18); }
      56% { transform: scale(1); }
    }

    @keyframes floatHeart {
      0% {
        opacity: 0;
        transform: translateY(0) rotate(0deg);
      }
      10% {
        opacity: 0.6;
      }
      80% {
        opacity: 0.3;
      }
      100% {
        opacity: 0;
        transform: translateY(-100vh) rotate(20deg);
      }
    }

    /* Responsive */
    @media (max-width: 540px) {
      .page {
        padding: 48px 24px 96px;
      }

      .photo-section {
        margin: 40px -24px;
      }

      .letter-header h1 {
        font-size: 2rem;
      }
    }
  </style>
</head>
<body>

  <div class="top-seal"></div>

  <!-- Floating hearts (spawned by JS) -->
  <div class="hearts-container" id="hearts-container"></div>

  <div class="page">

    <!-- Header -->
    <header class="letter-header">
      <h1>To Arthy my love<span class="heart">❤️</span></h1>
      <div class="divider"></div>
      <p class="subtitle">(Love letter)</p>
    </header>

    <!-- Opening -->
    <div class="letter-body">
      <blockquote>
        You are my hero mama, you are wonderful!
      </blockquote>

      <div class="mono-box">
        You are everything to me, I lovvvveeee you soooooo muchhhhhh!
      </div>

      <p>You are beautiful gorgeous baby girl 😘❤️</p>
    </div>

    <!-- Photo -->
    <div class="photo-section">
      <img
        src="/arthy-morning.jpg"
        alt="Morning at the river — our bench, our bridge, our sky"
        loading="eager"
      />
      <p class="photo-caption">27 Jan 2026 · 5:55 AM · Our spot</p>
    </div>

    <!-- Day counter -->
    <div class="day-counter">
      <div>
        <span class="count" id="day-count">1217</span>
        <span class="count-icons">❤️ 💯</span>
      </div>
      <p class="count-label">days of you being mine</p>
    </div>

    <!-- Continuation -->
    <div class="letter-continuation">
      <p>
        I'm soooooo lucky to have you!<br>
        Soon mana pelli aythadi, chalaaaaa happy ga chusukuntaaaaa.<br>
        Anni manchiga jarguthayi.
      </p>

      <p class="tinyact-line">
        What I'm doing is just a &ldquo;<span class="brand">TinyAct</span>&rdquo; of expressing my love towards You.
      </p>
    </div>

    <!-- Signature -->
    <div class="signature">
      <p class="closing">with love,</p>
      <p class="from">Your Mr.TinyAct.</p>
      <p class="timestamp">27/01/2026 &mdash; 5:55AM IST.</p>
    </div>

  </div>

  <div class="bottom-seal"></div>

  <script>
    // Spawn floating hearts
    const container = document.getElementById('hearts-container');
    const heartChars = ['❤️', '🩷', '💕', '💗'];

    function spawnHeart() {
      const el = document.createElement('span');
      el.className = 'floating-heart';
      el.textContent = heartChars[Math.floor(Math.random() * heartChars.length)];
      el.style.left = Math.random() * 100 + 'vw';
      el.style.fontSize = (10 + Math.random() * 14) + 'px';
      const dur = 7 + Math.random() * 8;
      el.style.animationDuration = dur + 's';
      el.style.animationDelay = Math.random() * 3 + 's';
      container.appendChild(el);
      setTimeout(() => el.remove(), (dur + 3) * 1000);
    }

    // Initial burst
    for (let i = 0; i < 6; i++) {
      setTimeout(() => spawnHeart(), i * 400);
    }

    // Ongoing trickle
    setInterval(spawnHeart, 2200);

    // Count-up for the day counter
    const countEl = document.getElementById('day-count');
    const target = 1217;
    const duration = 1800;
    const start = performance.now();

    function updateCount(now) {
      const t = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - t, 3);
      countEl.textContent = Math.round(ease * target);
      if (t < 1) requestAnimationFrame(updateCount);
    }

    // Wait for counter to be in view
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        requestAnimationFrame(updateCount);
        observer.disconnect();
      }
    }, { threshold: 0.5 });

    observer.observe(countEl);
  </script>
</body>
</html>
