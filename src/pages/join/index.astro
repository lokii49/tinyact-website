---
import Layout from '../../layouts/Layout.astro';

const appStoreUrl = "https://apps.apple.com/app/tinyact/id6758723462";
const playStoreUrl = "https://play.google.com/store/apps/details?id=com.lokesh.Tinyact";
---

<Layout
  title="Join a Commitment on TinyAct"
  description="You've been invited to join a commitment on TinyAct — the accountability habit app."
>
  <main class="join-page">
    <div class="card">
      <div class="logo">
        <img src="/favicon.png" alt="TinyAct" width="64" height="64" />
        <h1>TinyAct</h1>
      </div>

      <div class="invite-content">
        <div class="invite-icon">🤝</div>
        <h2>You're invited to join a commitment</h2>
        <p>Open TinyAct to see the commitment details and join your accountability group.</p>
      </div>

      <div class="actions">
        <a href="#" class="btn btn-primary" id="open-app">
          Open in TinyAct
        </a>
        <div class="store-links">
          <p class="store-label">Don't have TinyAct yet?</p>
          <div class="store-buttons">
            <a href={appStoreUrl} class="store-btn ios-btn" id="ios-store">
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              App Store
            </a>
            <a href={playStoreUrl} class="store-btn android-btn" id="android-store">
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                <path d="M3.18 23.76c.31.17.67.19 1.01.04l12.44-7.04-2.89-2.89-10.56 9.89zM.54 1.7C.2 2.03 0 2.54 0 3.2v17.6c0 .66.2 1.17.54 1.5l.08.08L9.69 13.3v-.2L.62 1.62l-.08.08zM20.46 10.16l-2.5-1.42-3.19 3.19 3.19 3.19 2.52-1.43c.72-.41.72-1.12-.02-1.53zM4.19.24L16.63 7.28l-2.89 2.89L3.18.28C3.52.13 3.88.07 4.19.24z"/>
              </svg>
              Google Play
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ appStoreUrl, playStoreUrl }}>
  // Extract code from URL path: /join/<code>
  const pathParts = window.location.pathname.split('/').filter(Boolean);
  const code = pathParts[pathParts.indexOf('join') + 1] || '';

  const ua = navigator.userAgent;
  const isIOS = /iPhone|iPad|iPod/.test(ua);
  const isAndroid = /Android/.test(ua);

  // Hide irrelevant store button
  const iosBtn = document.getElementById('ios-store');
  const androidBtn = document.getElementById('android-store');
  if (iosBtn && androidBtn) {
    if (isIOS) androidBtn.style.display = 'none';
    else if (isAndroid) iosBtn.style.display = 'none';
  }

  // "Open in TinyAct" — try custom scheme, fallback to store after 500ms
  const openAppBtn = document.getElementById('open-app');
  if (openAppBtn) {
    openAppBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (!code) {
        window.location.href = isAndroid ? playStoreUrl : appStoreUrl;
        return;
      }
      window.location.href = `microcommit://join/${code}`;
      setTimeout(() => {
        if (document.hasFocus()) {
          window.location.href = isAndroid ? playStoreUrl : appStoreUrl;
        }
      }, 500);
    });
  }
</script>

<style>
  .join-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: #f5f5f7;
  }

  .card {
    background: white;
    border-radius: 20px;
    padding: 40px 32px;
    max-width: 400px;
    width: 100%;
    text-align: center;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }

  .logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-bottom: 32px;
  }

  .logo h1 {
    font-size: 22px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
  }

  .invite-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .invite-content h2 {
    font-size: 20px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 12px;
  }

  .invite-content p {
    font-size: 15px;
    color: #666;
    margin: 0 0 32px;
    line-height: 1.5;
  }

  .btn-primary {
    display: block;
    background: #FF6B5A;
    color: white;
    text-decoration: none;
    padding: 14px 24px;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 24px;
    transition: opacity 0.15s;
  }

  .btn-primary:hover { opacity: 0.9; }

  .store-label {
    font-size: 13px;
    color: #999;
    margin: 0 0 12px;
  }

  .store-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
  }

  .store-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 10px;
    border: 1px solid #e0e0e0;
    text-decoration: none;
    color: #1a1a1a;
    font-size: 14px;
    font-weight: 500;
    transition: background 0.15s;
  }

  .store-btn:hover { background: #f5f5f7; }
</style>
